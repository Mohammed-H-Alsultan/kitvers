{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "shell:allow-open",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [{ "path": "**" }]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "node",
          "cmd": "node",
          "args": true,
          "sidecar": false
        },
        {
          "name": "binaries/node-engine",
          "cmd": "binaries/node-engine",
          "args": true,
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "node",
          "cmd": "node",
          "args": true,
          "sidecar": false
        },
        {
          "name": "binaries/node-engine",
          "cmd": "binaries/node-engine",
          "args": true,
          "sidecar": true
        }
      ]
    }
  ]
}
